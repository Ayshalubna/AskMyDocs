# ─── Application ──────────────────────────────────
APP_NAME="RAG Document Q&A"
ENVIRONMENT=development
DEBUG=false

# ─── LLM (Ollama) ─────────────────────────────────
# For local dev: OLLAMA_BASE_URL=http://localhost:11434
# For Docker:    OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
# Alternatives: llama3, phi3, gemma, codellama, mixtral
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120

# ─── Embeddings ───────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Alternatives:
#   sentence-transformers/all-mpnet-base-v2  (better quality, slower)
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2  (multilingual)
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ─── Vector Store ─────────────────────────────────
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MMR_LAMBDA=0.5

# ─── Storage ──────────────────────────────────────
UPLOAD_DIR=./storage/uploads
VECTOR_STORE_DIR=./storage/vectorstore
MAX_UPLOAD_SIZE_MB=50

# ─── HuggingFace Fallback ─────────────────────────
USE_HF_FALLBACK=true
HF_MODEL=google/flan-t5-base

# ─── Monitoring ───────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","*"]
